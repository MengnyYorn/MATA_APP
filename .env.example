# Google Sign-In Web client ID (must match MATA-API GOOGLE_CLIENT_ID audience)
# flutter run --dart-define=GOOGLE_SERVER_CLIENT_ID=your-id.apps.googleusercontent.com
# GOOGLE_SERVER_CLIENT_ID=

# API base URL is set in lib/core/constants/app_constants.dart (baseUrl).
# For devices, use your machine LAN IP, e.g. http://192.168.1.10:8087/api/v1
